# 这是假的示例配置，不要把真实密钥写进仓库。

# 阿里云通义千问（OpenAI 兼容接口）
DASHSCOPE_API_KEY=sk-your-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3.5-flash
DASHSCOPE_TIMEOUT=120

# 抓取与导出
SCRAPER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64)
SCRAPER_SLEEP_SECONDS=1.5
SCRAPER_TIMEOUT_SECONDS=20
SCRAPER_MAX_RETRIES=3
OUTPUT_PATH=data/fetched_heroes.json

# SQLite
SQLITE_PATH=data/game_recommender.sqlite3

# 日志
LOG_LEVEL=INFO

# 代理（如不需要可留空）
HTTP_PROXY=
HTTPS_PROXY=
