.hero-card {
  padding: 40rpx;
}

.hero-header {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.hero-avatar.large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-avatar .avatar-text {
  font-size: 64rpx;
  font-weight: bold;
  color: #fff;
}

.hero-basic .hero-name {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 20rpx;
}

.hero-tags {
  display: flex;
  gap: 15rpx;
}

.camp-tag, .type-tag {
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 28rpx;
}

.camp-tag {
  background: #e94560;
}

.type-tag {
  background: rgba(255, 255, 255, 0.2);
}

/* 属性卡片 */
.attrs-card {
  padding: 30rpx;
}

.attrs-grid {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.attr-item {
  text-align: center;
}

.attr-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.attr-value {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
}

.attr-value.attack {
  color: #ff6b6b;
}

.attr-value.defense {
  color: #4ecdc4;
}

.attr-value.speed {
  color: #ffc107;
}

/* 标签卡片 */
.tags-card {
  padding: 30rpx;
}

.tags-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  margin-top: 20rpx;
}

/* 克制卡片 */
.counter-card {
  padding: 30rpx;
}

.counter-list {
  margin-top: 20rpx;
}

.counter-info {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.counter-section {
  background: rgba(0, 0, 0, 0.2);
  padding: 20rpx;
  border-radius: 12rpx;
}

.counter-title {
  display: block;
  font-size: 26rpx;
  color: #a0a0a0;
  margin-bottom: 15rpx;
}

.no-data {
  color: #666;
  font-size: 26rpx;
  text-align: center;
  padding: 30rpx;
}
