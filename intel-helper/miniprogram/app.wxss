/**
 * 小程序全局样式
 */
page {
  background-color: #16213e;
  color: #ffffff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

.container {
  min-height: 100vh;
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

/* 标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #e94560;
  margin-bottom: 30rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #e94560;
}

/* 按钮样式 */
.btn {
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #ffffff;
  border: none;
}

.btn-primary:active {
  transform: scale(0.95);
  opacity: 0.9;
}

.btn-secondary {
  background: transparent;
  color: #a0a0a0;
  border: 2rpx solid #a0a0a0;
}

.btn-success {
  background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
  color: #ffffff;
  border: none;
}

/* 输入框样式 */
.input {
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  color: #ffffff;
  font-size: 28rpx;
}

.input:focus {
  border-color: #e94560;
  outline: none;
}

.input::placeholder {
  color: #666;
}

/* 标签样式 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin: 8rpx;
}

.tag-primary {
  background: rgba(233, 69, 96, 0.2);
  color: #e94560;
  border: 1rpx solid #e94560;
}

.tag-success {
  background: rgba(78, 205, 196, 0.2);
  color: #4ecdc4;
  border: 1rpx solid #4ecdc4;
}

.tag-warning {
  background: rgba(255, 193, 7, 0.2);
  color: #ffc107;
  border: 1rpx solid #ffc107;
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 60rpx;
  color: #a0a0a0;
}

.loading::before {
  content: '';
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e94560;
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
  color: #666;
}

.empty-state image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: rgba(255, 255, 255, 0.1);
  margin: 30rpx 0;
}
